<%- include('partials/head') %>
<style>
    *{
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body{
    background-color: lightgray;
    height: 100vh;
    width: 100vw;
    overflow-x: hidden;
}

nav{
    display: flex;
    align-items: center;
    justify-content :space-around;
    /* flex-direction: column; */
    width: 100%;
    height: 100px;
    background-color: rgb(43, 43, 43);
}

.logo{
    width: 40%;
    height: 40px;
    color: white;
    font-size: 50px;
}

ul{
    list-style: none;
}

.nav{
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 40px;
    margin-left: 100px;
}

.nav a {
    text-decoration: none;
    color: white;
    font-size: 20px;
}

.allNote{
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-gap: 10px;
    width: 70%;
    margin: 40px auto;
}
.note{
    display: flex;
    flex-direction: column;
    border-radius: 10px;
    gap : 20px;
    height: 200px;
    border: 2px solid black;
    margin: 10px;
    padding: 10px;
    background-color: white;
    width: 90%;
}

.content b {
    font-size: 20px;
}

.btn{
    margin-top: 20px;
    display: flex;
    gap: 40px;
}
.edit{
    width: 100px;
    padding: 8px 8px;
    font-size: 17px;
    background-color: green;
    color: white;
    border-radius: 15px;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    text-decoration: none;
    text-align: center;

}

.delete{
    width: 150px;
    padding: 8px 8px;
    background-color: red;
    border-radius: 15px;
    text-transform: uppercase;
    font-size: 17px;
    color: white;
    border: none;
    cursor: pointer;
    text-decoration: none;
    text-align: center;
}


</style>
</head>
<body>
    <nav>
        <h2 class="logo">Express Notes</h2>
        <ul class="nav">
            <li><a href="/note/add-note">Add Note</a></li>
            <li><a href="/logout">Logout</a></li>
        </ul>
    </nav>

    <div class="allNote">
    <% notes.forEach(function(note){ %>
        <div class="note">
            <div class="title">
                <h2> Title :  <%= note.title %></h2>
            </div>
            <div class="content">
                <p> <b> Content : </b>  <%= note.content %> </p>
            </div>
            <div class="btn">
                <a href="/note/edit/<%= note.id %>" class="edit">Edit</a>
                <a href="/note/delete/<%= note.id %>" class="delete">Delete</a>
            </div>
        </div>

    <% }) %>
    </div>

</body>
</html>