<%- include('partials/head') %>
<style>
    *{
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

    body {
    background-color: lightgray;
    height: 100vh;
    width: 100vw;
    overflow-x: hidden;
    font-family: Arial, sans-serif;
    color: white;
}
nav{
    display: flex;
    align-items: center;
    justify-content :space-around;
    /* flex-direction: column; */
    width: 100%;
    height: 100px;
    background-color: rgb(43, 43, 43);
}

h2{
    width: 40%;
    height: 40px;
    color: white;
    font-size: 50px;
}

.nav{
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 40px;
}
ul{
    list-style: none;
}

.nav a {
    text-decoration: none;
    color: white;
    font-size: 20px;
}

/* Center form */
form {
    width: 400px;
    margin: 100px auto;
    padding: 20px;
    background-color: #112d4e;
    border-radius: 8px;
}

/* Inputs */
input {
    width: 90%;
    padding: 8px;
    margin: 10px 10px;
    border: none;
    border-radius: 5px;
}

/* Button */
.btn {
    width: 93%;
    padding: 8px;
    margin: 10px 10px;
    background-color: #3f72af;
    color: white;
    cursor: pointer;
}

.btn:hover {
    background-color: #2c5d9e;
}

textarea {
    width: 90%;
    padding: 8px;
    margin: 10px 10px;
    border: none;
    border-radius: 5px;
    resize: none;        /* optional: disable resize */
    height: 80px;
    font-family: Arial, sans-serif;
}
</style>

</head>

<body>

    <nav>
        <h2>Express Notes</h2>
        <ul class="nav">
            <li><a href="/note/add-note">Add Note</a></li>
            <li><a href="/logout">Logout</a></li>
        </ul>
    </nav>
    <form method="post" action=<%= edit == "true" ? '/note/edit/'+noteID : "/note/dashboard" %> >
            <input type="text" name="title" placeholder="Title"  required class="title" value=<%= edit == "true" ? noteTitle : '' %> >

            <textarea name="content" placeholder="content" required class="content"><%= edit == "true" ? noteContent : '' %></textarea>
            <input type="submit" value=<%= edit == "true" ? "Edit" : 'Add' %> class="btn">
    </form>
    <p> <%= edit %> </p>
</body>
</html>

