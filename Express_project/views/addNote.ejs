<%- include('partials/head') %>
<style>
    body {
    background-color: #0b1f3a;
    font-family: Arial, sans-serif;
    color: white;
}
nav{
    display: flex;
    align-items: center;
    justify-content :space-around;
    /* flex-direction: column; */
    width: 100%;
    height: 100px;
    background-color: rgb(21, 21, 21);
}

h2{
    width: 40%;
    height: 40px;
    color: white;
    font-size: 50px;
}

.nav{
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 40px;
    margin-left: 100px;
}

.nav a {
    text-decoration: none;
    color: white;
    font-size: 30px;
}

/* Center form */
form {
    width: 400px;
    margin: 100px auto;
    padding: 20px;
    background-color: #112d4e;
    border-radius: 8px;
}

/* Inputs */
input {
    width: 90%;
    padding: 8px;
    margin: 10px 10px;
    border: none;
    border-radius: 5px;
}

/* Button */
.btn {
    width: 93%;
    padding: 8px;
    margin: 10px 10px;
    background-color: #3f72af;
    color: white;
    cursor: pointer;
}

.btn:hover {
    background-color: #2c5d9e;
}

textarea {
    width: 90%;
    padding: 8px;
    margin: 10px 10px;
    border: none;
    border-radius: 5px;
    resize: none;        /* optional: disable resize */
    height: 80px;
    font-family: Arial, sans-serif;
}
</style>

</head>

<body>

    <nav>
        <h2>Express Notes</h2>
        <ul class="nav">
            <li><a href="/note/add-note">Add Note</a></li>
            <li><a href="/logout">Logout</a></li>
        </ul>
    </nav>

    <form action="/note/add-note" method="POST">
    <input type="text" name="title" placeholder="Title" required class="title">

    <textarea name="content" placeholder="Content" required class="content"></textarea>
    <input type="submit" value="Add Note" class="btn">
</form>
</body>
</html>